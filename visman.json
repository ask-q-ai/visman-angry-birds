      },
      "style": {
        "fillStyle": "#4d3319",
        "strokeStyle": "#228B22",
        "lineWidth": 4
      },
      "physics": {
        "bodyType": "static",
        "friction": 0.8
      },
      "collision": {
        "collisionGroups": [
          "ground"
        ]
      }
    },
    {
      "id": "slingshot-back",
      "context": "canvas",
      "type": "line",
      "position": {
        "x": 100,
        "y": 320
      },
      "properties": {
        "x2": 100,
        "y2": 260
      },
      "style": {
        "strokeStyle": "#5d4037",
        "lineWidth": 8
      }
    },
    {
      "id": "slingshot-fork-left",
      "context": "canvas",
      "type": "line",
