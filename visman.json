  "canvasLayer": [
    {
      "id": "bg",
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": 0,
        "y": 0
      },
      "size": {
        "width": 640,
        "height": 360
      },
      "style": {
        "fillStyle": "#87CEEB",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      }
    },
