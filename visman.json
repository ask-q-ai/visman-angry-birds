    {
      "id": "ui-score",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 20,
        "y": 20
      },
      "properties": {
        "text": "SCORE: {{ @vm.score }}"
      },
      "style": {
        "color": "#FFFFFF",
        "fontSize": 24,
        "fontWeight": "bold"
      }
    },
