    {
      "id": "controller",
      "context": "canvas",
      "type": "circle",
      "position": {
        "x": 100,
        "y": 245
      },
      "size": {
        "radius": 12
      },
      "style": {
        "fillStyle": "#FF5252",
        "strokeStyle": "#B71C1C",
        "lineWidth": 2
      },
      "callbacks": {
        "onKeyDown": {
          "Space": "launch"
        },
        "onKeyHeld": {
          "ArrowUp": "aim_up",
          "ArrowDown": "aim_down",
          "ArrowLeft": "power_less",
          "ArrowRight": "power_more"
        }
      },
      "actions": {
        "aim_up": {
          "stateMutations": [
            {
              "path": "vm.vy",
              "operation": "decrement",
              "value": 5
            }
          ]
        },
        "aim_down": {
          "stateMutations": [
            {
              "path": "vm.vy",
              "operation": "increment",
              "value": 5
            }
          ]
        },
        "power_more": {
          "stateMutations": [
            {
              "path": "vm.vx",
              "operation": "increment",
              "value": 5
            }
          ]
        },
        "power_less": {
          "stateMutations": [
            {
              "path": "vm.vx",
              "operation": "decrement",
              "value": 5
            }
          ]
        },
        "launch": {
          "stateMutations": [
            {
              "path": "vm.birdsLeft",
              "operation": "decrement",
              "value": 1
            }
          ],
          "spawn": {
            "template": {
              "type": "circle",
              "size": {
                "radius": 10
              },
              "style": {
                "fillStyle": "#FF5252",
                "strokeStyle": "#222222",
                "lineWidth": 1
              },
              "physics": {
                "kinematic": true,
                "bodyType": "dynamic",
                "vx": "{{ @vm.vx }}",
                "vy": "{{ @vm.vy }}",
                "ay": 800,
                "bounce": 0.3,
                "friction": 0.2,
                "destroyOutOfBounds": true
              },
              "collision": {
                "collisionGroups": [
                  "bird"
                ],
                "collidesWith": [
                  "structure",
                  "pig",
                  "ground"
                ]
              }
            }
          }
        }
      }
    },
