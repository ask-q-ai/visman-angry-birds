        "x": 100,
        "y": 260
      },
      "properties": {
        "x2": 80,
        "y2": 230
      },
      "style": {
        "strokeStyle": "#5d4037",
        "lineWidth": 6
      }
    },
    {
      "id": "slingshot-fork-right",
      "context": "canvas",
      "type": "line",
      "position": {
        "x": 100,
        "y": 260
      },
      "properties": {
        "x2": 120,
        "y2": 230
      },
      "style": {
        "strokeStyle": "#5d4037",
